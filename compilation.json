        "tailscale"
      ]
    },
    {
      "id": "r010",
      "type": "recommendation",
      "topic": "security",
      "content": "For short-term fixed sessions: ngrok with --auth is adequate. For anything longer or multi-user: Cloudflare Tunnel with Access policies preferred (free tier, email OTP auth, no trust dependency on third-party infra for inspection). Tailscale is best if both endpoints can install a client.",
      "source": {
        "origin": "analysis",
        "artifact": null,
        "connector": null
      },
      "evidence": "web",
      "status": "active",
      "phase_added": "research",
