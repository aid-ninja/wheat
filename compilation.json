    {
      "id": "r008",
      "type": "risk",
      "topic": "security",
      "content": "Check Point Research found CVEs (CVE-2025-59536, CVE-2026-21852) where malicious .claude/settings.json enables RCE through hooks. Hook URLs in settings are plaintext. For our dashboard this means: the hook config itself is a security-sensitive file, and the localhost HTTP endpoint must be authenticated.",
      "source": {
