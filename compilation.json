      ]
    },
    {
      "id": "r009",
      "type": "factual",
      "topic": "security",
      "content": "Ngrok provides TLS tunnels with ephemeral URLs, optional --auth (basic auth), and IP allowlisting on paid plans. Traffic routes through ngrok's infrastructure (trust dependency). Cloudflare Tunnel runs through your own CF account with Zero Trust access policies (email OTP, no client install). Tailscale uses WireGuard mesh VPN with ACLs — zero public exposure but requires client on both ends.",
      "source": {
        "origin": "web",
        "artifact": "ngrok/cloudflare/tailscale docs",
        "connector": null
      },
      "evidence": "web",
      "status": "active",
      "phase_added": "research",
