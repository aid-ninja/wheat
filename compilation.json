    {
      "id": "r012",
      "type": "factual",
      "topic": "architecture",
      "content": "Claude Code has 5 permission modes: default (prompt each tool), acceptEdits (auto-accept file edits), plan (read-only), dontAsk (deny unless pre-approved), bypassPermissions (skip all checks). The dashboard should be aware of the current mode and adjust its behavior — e.g., in acceptEdits mode, only non-edit tools trigger approval requests.",
      "source": {
        "origin": "documentation",
        "artifact": "Claude Code permissions reference",
        "connector": null
      },
      "evidence": "documented",
      "status": "active",
      "phase_added": "research",
