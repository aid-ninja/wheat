    {
      "id": "r011",
      "type": "recommendation",
      "topic": "architecture",
      "content": "Recommended architecture: Node.js HTTP server on localhost receives hook POSTs from Claude Code. Server holds pending permission requests in memory. Browser connects via WebSocket for real-time push. User approves/denies in browser, server responds to the held HTTP request. PostToolUse hooks feed activity stream. claims.json watched via fs.watch for sprint dashboard updates.",
      "source": {
        "origin": "analysis",
        "artifact": null,
        "connector": null
      },
